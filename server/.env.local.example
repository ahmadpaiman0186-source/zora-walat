# Copy to .env.local (gitignored). Overrides server/.env — good place for STRIPE_SECRET_KEY on Windows.
#
# Zero-trust (owner-only identity + optional payment freeze; see server/src/middleware/ownerOnlyAccessGuard.js
# and PAYMENTS_LOCKDOWN_MODE in server/src/config/env.js):
# OWNER_ALLOWED_EMAIL=operator@example.com
# ZW_REQUIRE_OWNER_ALLOWED_EMAIL=true
#   When true, API refuses to start if OWNER_ALLOWED_EMAIL is empty/invalid (private/operator deploys).
# PAYMENTS_LOCKDOWN_MODE=true
#   When true, new checkouts / wallet top-up / money creation return 503; webhooks unchanged.
#
PORT=8787
# Next.js local dev: browser on :3000 calling API on :8787 needs these origins in CORS (when PRELAUNCH_LOCKDOWN is false).
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8787,http://127.0.0.1:8787
# Flutter web (`flutter run -d chrome`) uses a random port. If NODE_ENV=production and API blocks login (CORS), set either
# a matching CORS_ORIGINS/CLIENT_URL for that port, or: ZW_ALLOW_LOCAL_FLUTTER_WEB_CORS=true
# Optional: CORS_DEBUG_LOG=true — log each request CORS decision at info (see corsRequestDebugLog.js); else debug level only
CLIENT_URL=
STRIPE_SECRET_KEY=

# Customer-facing government sales tax on product value (recipient USD), basis points per sender region code (US, CA, EU, AE, TR).
# Omitted or empty = 0% for all — this is the default until you set real jurisdictional rates.
# Example (illustrative only — confirm with counsel): 8.25% for US → 825 bps
# PHASE1_GOVERNMENT_SALES_TAX_BPS_BY_SENDER={"US":825,"CA":500}
# Optional JSON body field billingJurisdiction (US state, city, ZIP) is accepted and stored
# on PaymentCheckout.pricingSnapshot; Phase-1 tax BPS is still senderCountry-only until
# a provider (e.g. Stripe Tax) is enabled — see pricingMeta.jurisdictionAppliedToTax.

# Zora line-item service fee: minimum basis points of **product value** before margin search.
# Default 100 = 1% of face (e.g. $0.02 on a $2 top-up). Prevents fee=0 when PRICING_AMOUNT_ONLY_PROVIDER_BPS
# is set so low that margin is met without a separate fee. Set to 0 to allow fee=0 again (legacy).
# PHASE1_MIN_ZORA_SERVICE_FEE_BPS=100

# Local checkout (NODE_ENV=development only): allow authenticated users without verified email on POST /create-checkout-session.
# Set to false to enforce email verification like production while developing.
# ALLOW_UNVERIFIED_CHECKOUT=true

# Money routes (checkout, wallet top-up, etc.) return 503 while pre-launch lockdown is on. Use false for normal local Stripe checkout.
# PRELAUNCH_LOCKDOWN=false
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/zora_walat?schema=public"
# Prisma pool cap (appended as connection_limit= when absent from URL). Under `npm test` defaults to 10 if unset.
# PRISMA_CONNECTION_LIMIT=20
# npm test sets PRISMA_CONNECTION_LIMIT=3 and rewrites DATABASE_URL (see test/setupTestEnv.mjs).
# If tests fail with FATAL: too many clients, stop other processes using this DB (API, worker, Studio).

# --- Optional: controlled Stripe LIVE checkout proof (local / staging) ---
# ZW_CONTROLLED_STRIPE_LIVE_PROOF=true
# ZW_STRIPE_LIVE_PROOF_MAX_FINAL_USD_CENTS=226
# ZW_STRIPE_LIVE_PROOF_ALLOWED_RECIPIENTS=701234567
# Requires PHASE1_FULFILLMENT_OUTBOUND_ENABLED unset/false. Caps server-priced **final** total (cents, includes tax+fees).
# Smallest Phase 1 SKU is 200¢ product; with default fees the total is higher than 100¢ — set cap ≥ your priced total (see `npm run verify:local-pricing`).

# --- Phase 1 fulfillment (Stripe Checkout → airtime) ---
# `AIRTIME_PROVIDER` defaults to `mock` when unset (startup log: airtime=mock). Mock completes
# instantly with no Reloadly HTTP. Set `reloadly` + Reloadly env below for real sandbox I/O.
#
# BullMQ: when BOTH `FULFILLMENT_QUEUE_ENABLED=true` AND `REDIS_URL` are set, paid orders enqueue
# to Redis and ONLY `npm run worker:fulfillment` drains them. `npm start` alone will NOT finish
# delivery in that mode — UI stays "Preparing" until the worker runs. For typical local sandbox
# with one terminal, leave FULFILLMENT_QUEUE_ENABLED unset/false so fulfillment runs inline.
# FULFILLMENT_QUEUE_ENABLED=false
# REDIS_URL=redis://127.0.0.1:6379

# Airtime — Reloadly sandbox (server-only; never in client)
# AIRTIME_PROVIDER=reloadly
# RELOADLY_CLIENT_ID=xxxx
# RELOADLY_CLIENT_SECRET=xxxx
# RELOADLY_SANDBOX=true
# RELOADLY_BASE_URL=https://topups-sandbox.reloadly.com
# RELOADLY_AUTH_URL=https://auth.reloadly.com/oauth/token
# RELOADLY_OPERATOR_MAP_JSON={"roshan":"<numeric_operator_id_from_Reloadly>"}

# WebTopup — durable Reloadly circuit (DB-backed; default on). Thresholds within sliding window → open; cooldown → half-open probes.
# WEBTOPUP_RELOADLY_DURABLE_CIRCUIT_ENABLED=false
# WEBTOPUP_RELOADLY_CIRCUIT_FAILURE_THRESHOLD=5
# WEBTOPUP_RELOADLY_CIRCUIT_WINDOW_MS=120000
# WEBTOPUP_RELOADLY_CIRCUIT_COOLDOWN_MS=120000
# WEBTOPUP_RELOADLY_CIRCUIT_HALF_OPEN_MAX_PROBES=2

# WebTopup — SLA / timeout policy (see webtopSlaPolicy.js). Aligns with RECONCILE_* stuck thresholds unless overridden.
# WEBTOPUP_SLA_PAYMENT_PENDING_MAX_MS=1800000
# WEBTOPUP_SLA_PAID_TO_DELIVERED_MAX_MS=3600000
# WEBTOPUP_SLA_PAID_TO_DELIVERED_WARN_RATIO=0.7
# WEBTOPUP_SLA_WARN_RATIO=0.7
# WEBTOPUP_SLA_ENFORCEMENT_ENABLED=true
# WEBTOPUP_SLA_ENFORCEMENT_PROCESSING_GRACE_MS=45000
# WEBTOPUP_UX_PUBLIC_FIELDS_ENABLED=true

# WebTopup — advanced in-process abuse heuristics (see webtopAbuseProtection.js). Blocks return code webtopup_abuse_blocked + abuseReason.
# WEBTOPUP_ABUSE_BURST_WINDOW_MS=120000
# WEBTOPUP_ABUSE_BURST_MAX_PER_WINDOW=40
# WEBTOPUP_ABUSE_PI_CHURN_WINDOW_MS=300000
# WEBTOPUP_ABUSE_PI_CHURN_MAX_PER_WINDOW=20
# WEBTOPUP_ABUSE_MULTI_TARGET_WINDOW_MS=900000
# WEBTOPUP_ABUSE_MULTI_TARGET_DISTINCT_MAX=14
# WEBTOPUP_ABUSE_PHONE_SPAM_WINDOW_MS=600000
# WEBTOPUP_ABUSE_PHONE_SPAM_MAX_PER_WINDOW=10
# WEBTOPUP_ABUSE_FAILED_PAYMENT_WINDOW_MS=900000
# WEBTOPUP_ABUSE_FAILED_PAYMENT_MAX=8

# WebTopup — financial guardrails (pre-dispatch). Amount bounds, allowed currencies, optional rolling cap per phone analytics hash.
# WEBTOPUP_FINANCIAL_MIN_AMOUNT_CENTS=1
# WEBTOPUP_FINANCIAL_MAX_AMOUNT_CENTS=10000000
# WEBTOPUP_FINANCIAL_ALLOWED_CURRENCIES=usd
# WEBTOPUP_FINANCIAL_DAILY_CAP_CENTS_PER_PHONE=0
# WEBTOPUP_FINANCIAL_DAILY_CAP_WINDOW_HOURS=24

# WebTopup async worker (WEBTOPUP_FULFILLMENT_ASYNC) — batch size, lease recovery, stale heuristics for ops.
# WEBTOPUP_FULFILLMENT_JOB_BATCH_SIZE=15
# WEBTOPUP_FULFILLMENT_JOB_LEASE_MS=300000
# WEBTOPUP_FULFILLMENT_STALE_QUEUED_ORDER_MS=900000
# WEBTOPUP_FULFILLMENT_STALE_PROCESSING_ORDER_MS=1800000

# WebTopup — durable NDJSON log sink (append-only; optional rotation by size). Does not replace in-memory buffer.
# WEBTOPUP_DURABLE_LOG_ENABLED=true
# WEBTOPUP_DURABLE_LOG_PATH=./logs/webtopup-events.ndjson
# WEBTOPUP_DURABLE_LOG_MAX_BYTES=52428800

# Admin — WebTopup control routes (`/api/admin/webtopup/*`). Legacy: ADMIN_SECRET (>=16 chars).
# Rotation: set ADMIN_SECRET_CURRENT (+ optional ADMIN_SECRET_PREVIOUS); legacy ADMIN_SECRET ignored when CURRENT is set.
# ADMIN_SECRET_CURRENT=
# ADMIN_SECRET_PREVIOUS=
# Optional IP allowlist (comma-separated). Empty = disabled. Example: 127.0.0.1,::1
# ADMIN_ALLOWED_IPS=
# Stricter buckets for WebTopup admin (per client IP, 15m window; see adminSecurity in GET .../monitoring).
# WEBTOPUP_ADMIN_MUTATION_MAX_PER_15M=20
# WEBTOPUP_ADMIN_READ_MAX_PER_15M=80

# WebTopup — GET /api/admin/webtopup/monitoring thresholds (alert-oriented).
# WEBTOPUP_MONITORING_STALE_PROCESSING_WARN=1
# WEBTOPUP_MONITORING_STALE_QUEUED_WARN=1
# WEBTOPUP_MONITORING_FULFILLMENT_FAIL_WARN=5
# WEBTOPUP_MONITORING_FALLBACK_APPLIED_WARN=1
