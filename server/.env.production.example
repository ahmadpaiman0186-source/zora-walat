# =============================================================================
# Production secrets checklist — placeholders only. Do not paste real values into git.
# Inject at runtime via your host (Kubernetes secrets, Render/Fly/Railway env UI,
# AWS/GCP/Azure secret stores, Vault, Doppler, 1Password, etc.).
#
# Local development narrative + defaults: see tracked `server/.env.example`.
# Optional local overrides (gitignored): `server/.env.local`.
# Bootstrap order: `server/bootstrap.js` loads `.env` then `.env.local`; when
# `NODE_ENV=production`, the first dotenv pass does not override platform-injected env.
#
# Rotation + classification: `server/docs/SECRETS_MANAGEMENT.md`
# =============================================================================

NODE_ENV=production

# --- PostgreSQL (application data; rotate DB password via provider + connection string update) ---
DATABASE_URL=

# --- Redis (BullMQ, optional distributed rate limits) ---
REDIS_URL=

# --- Stripe (payment + webhook verification — distinct roles; rotate in Dashboard) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional alignment for preflight / Flutter: same mode as STRIPE_SECRET_KEY
# STRIPE_PUBLISHABLE_KEY=

# --- JWT (access + refresh — rotate with session invalidation plan) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=
REFRESH_TOKEN_TTL=

# --- Admin / operator APIs (Bull Board, WebTopup admin — separate from JWT) ---
# Prefer rotation pair over a single legacy secret:
# ADMIN_SECRET_CURRENT=
# ADMIN_SECRET_PREVIOUS=
# ADMIN_SECRET=
OPS_HEALTH_TOKEN=

# --- SMTP / transactional email + OTP (separate from Stripe and JWT) ---
# OTP_TRANSPORT=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# Legacy fallback names also supported by email stack: EMAIL_HOST, EMAIL_PORT, EMAIL_USER, EMAIL_PASS

# --- Reloadly (OAuth client — separate from Stripe; rotate in Reloadly dashboard) ---
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
# RELOADLY_SANDBOX=false
# RELOADLY_BASE_URL=
# RELOADLY_AUTH_URL=

# --- Public origins (not secrets; required for production startup gates) ---
CLIENT_URL=
CORS_ORIGINS=

# --- Optional hardening ---
# TRUST_PROXY_HOPS=1
# PRELAUNCH_LOCKDOWN=
# PAYMENTS_LOCKDOWN_MODE=
# OWNER_ALLOWED_EMAIL=
# ZW_REQUIRE_OWNER_ALLOWED_EMAIL=
