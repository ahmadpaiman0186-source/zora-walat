# Copy to server/.env and fill values. Never commit real secrets.
# Optional: server/.env.local overrides these (gitignored).
#
# --- Local development (minimal checklist) ---
# 1) PostgreSQL running; DATABASE_URL=postgresql://…
# 2) JWT_ACCESS_SECRET and JWT_REFRESH_SECRET (each >= 32 chars, different values)
# 3) STRIPE_SECRET_KEY=sk_test_… to exercise Checkout (see Stripe Dashboard)
# 4) PRELAUNCH_LOCKDOWN=false for local Checkout / wallet / recharge routes (default in snippet below)
# 5) Flutter web: default API is http://127.0.0.1:8787 — see repo README + lib/core/config/app_config.dart
# 6) Quieter logs while testing auth only: RELOADLY_AF_PROBE_ON_STARTUP=false (Reloadly code stays enabled)
#
# === Required for API startup (see src/index.js) ===
# DATABASE_URL — PostgreSQL connection string (postgresql://…)
# JWT_ACCESS_SECRET — >= 32 characters, unique random string
# JWT_REFRESH_SECRET — >= 32 characters, different from JWT_ACCESS_SECRET
#
# === Stripe (test mode: sk_test_… / live: sk_live_…) ===
# STRIPE_SECRET_KEY — API secret from Dashboard (server-only)
# STRIPE_WEBHOOK_SECRET — whsec_… from Dashboard webhook endpoint or `stripe listen` output.
#   Required when PRELAUNCH_LOCKDOWN=true. Strongly recommended for any checkout webhook testing.
#
# === Lockdown & CORS ===
# PRELAUNCH_LOCKDOWN — true = money routes return 503; strict CORS; extra startup checks.
#   false = allow POST /create-checkout-session, /api/wallet/topup, /api/recharge/order (still auth + rate limits).
# CORS_ORIGINS — comma-separated full origins. Production: no * (startup fails on wildcards).
#   When PRELAUNCH_LOCKDOWN=true in production, use explicit CORS_ORIGINS only.
#   In development, localhost / 127.0.0.1 on any port are allowed for Flutter web (see corsPolicy.js).
#
# === Production-only (index.js enforces when NODE_ENV=production) ===
# CLIENT_URL — HTTPS app origin for Stripe success/cancel (no trailing slash)
# ACCESS_TOKEN_TTL / REFRESH_TOKEN_TTL — set explicitly in production
#
# === Optional ===
# WEBTOPUP_FULFILLMENT_PROVIDER — `mock` (default) | `reloadly` for WebTopupOrder admin dispatch (AF + airtime only initially).
#   When `reloadly`, RELOADLY_CLIENT_ID and RELOADLY_CLIENT_SECRET must be set (startup validates).
# WEBTOPUP_FULFILLMENT_ASYNC — `true` to enqueue WebTopupFulfillmentJob after QUEUED (provider I/O off HTTP path; worker polls).
# WEBTOPUP_FULFILLMENT_JOB_POLL_MS — worker interval in ms (default 3000; set 0 to disable in-process polling).
# LOYALTY_POINTS_USD_BASIS_CENTS — cents per 1 loyalty point (default 100 → $1 = 1 point). No randomness; grants on delivered orders only.
# WEBTOPUP_FAILSIM — mock only: timeout | retry | terminal | unsupported (failure simulation).
# NODE_ENV — defaults to development if unset (see src/config/env.js)
# LOG_LEVEL — info | debug | …
# PORT — default 8787
#
# Prisma CLI: use npm run db:migrate / db:validate so server/bootstrap.js loads server/.env
# before Prisma runs (avoids stale DATABASE_URL in the shell on Windows).

# Server
PORT=8787
NODE_ENV=development
LOG_LEVEL=info

# Database — PostgreSQL only (Prisma)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/zora_walat?schema=public

# Reverse-proxy hops for Express (production only). Default 1. Use 2 if CDN + LB.
# TRUST_PROXY_HOPS=1

# Stripe — Secret key from Dashboard (server-only; not pk_…)
# Optional: one-line file server/stripe_secret.key instead (gitignored)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (Dashboard → Webhooks → signing secret). Server-only.
STRIPE_WEBHOOK_SECRET=

# TEMP TEST MODE — optional; local dev only. Never set DEV_CHECKOUT_AUTH_BYPASS in production (startup fails).
# DEV_CHECKOUT_AUTH_BYPASS=true
# DEV_CHECKOUT_BYPASS_SECRET=
# DEV_CHECKOUT_BYPASS_USER_ID=

# Stripe Checkout return URLs (production only):
# Set your deployed web app origin, no trailing slash (e.g. https://app.example.com).
# In development, leave unset — the API uses the browser `Origin` header from the checkout POST.
# CLIENT_URL=

# CORS: comma-separated full origins. No * or wildcards (production startup fails if invalid).
# PRELAUNCH_LOCKDOWN=true: only http://localhost:3000 and http://127.0.0.1:3000 are allowed (exact match).
# If unset under pre-launch, those two are applied by default.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PRELAUNCH_LOCKDOWN=true — zero–money-movement mode:
# - Blocks POST /create-checkout-session, POST /api/wallet/topup, POST /api/recharge/order (503).
# - Strict CORS to localhost:3000 / 127.0.0.1:3000 only.
# - Requires DATABASE_URL, STRIPE_WEBHOOK_SECRET, JWT secrets; minimal HTTP access logs only.
# PRELAUNCH_LOCKDOWN=false

# JWT auth — server-only. Generate strong random strings (≥32 chars each), different values.
JWT_ACCESS_SECRET=replace_with_at_least_32_character_random_secret_a
JWT_REFRESH_SECRET=replace_with_at_least_32_character_random_secret_b
# Access token TTL (seconds). Production: must set explicitly.
ACCESS_TOKEN_TTL=900
# Refresh token TTL (seconds). Production: must set explicitly.
REFRESH_TOKEN_TTL=604800

# Pricing engine (USD checkout). Tune Stripe fee to match your Stripe pricing.
# PRICING_STRIPE_FEE_BPS=290
# PRICING_STRIPE_FIXED_CENTS=30
# PRICING_FX_BPS=0
# PRICING_TAX_BPS=0
# Amount-only airtime: wholesale as basis points of selected face value (9000 = 90%).
# PRICING_AMOUNT_ONLY_PROVIDER_BPS=9000

# Margin intelligence (admin analytics): flag low net-to-sell routes (500 = 5%).
# MARGIN_LOW_ROUTE_BP=500

# Airtime fulfillment — server-only API; never embed in Flutter/web or public env.
# AIRTIME_PROVIDER=mock
# AIRTIME_PROVIDER_TIMEOUT_MS=30000
# RELOADLY_CLIENT_ID=
# RELOADLY_CLIENT_SECRET=
# RELOADLY_SANDBOX=true
# RELOADLY_BASE_URL — optional; defaults to sandbox or production topups host from RELOADLY_SANDBOX
# RELOADLY_BASE_URL=https://topups-sandbox.reloadly.com
# RELOADLY_AUTH_URL — optional OAuth token endpoint (default https://auth.reloadly.com/oauth/token)
# RELOADLY_AUTH_URL=https://auth.reloadly.com/oauth/token
# RELOADLY_OPERATOR_MAP_JSON — internal operatorKey → Reloadly numeric operator id (JSON object, server-only).
# Merges with defaults in server/src/config/reloadlyOperatorIdDefaults.js (non-empty env keys win).
# Example: {"roshan":"12345","mtn":"67890","etisalat":"111","afghanwireless":"222"}
# RELOADLY_OPERATOR_MAP_JSON=
# FULFILLMENT_DRAIN_INTERVAL_MS — background drain for queued attempts (ms). Default 120000; 0 disables. See src/index.js.
# FULFILLMENT_DRAIN_INTERVAL_MS=120000
# RELOADLY_AF_PROBE_ON_STARTUP=false — skip Afghanistan operator probe on boot (quieter logs when testing auth only).

# === Redis (optional) ===
# REDIS_URL — Redis connection string for distributed anti-abuse state (server-only).
# Example: redis://127.0.0.1:6379/0
# REDIS_CONNECT_TIMEOUT_MS — Redis connect timeout (ms). Default 2000.
# REDIS_CONNECT_TIMEOUT_MS=2000

# === TEMP local-only: checkout without JWT (non-production; remove before production) ===
# DEV_CHECKOUT_AUTH_BYPASS=true
# DEV_CHECKOUT_BYPASS_SECRET= — >=16 chars; must match Flutter --dart-define=DEV_CHECKOUT_BYPASS_SECRET
# DEV_CHECKOUT_BYPASS_USER_ID= — existing User.id from DB (PaymentCheckout.userId FK)

# === Web top-up fulfillment hardening (AF + airtime scope unchanged) ===
# FULFILLMENT_DISPATCH_ENABLED — default on; set false to reject all web top-up dispatch/retry (503).
# FULFILLMENT_DISPATCH_KILL_SWITCH — emergency stop; all dispatch/retry return 503 immediately.
# RELOADLY_WEBTOPUP_PROVIDER_ACTIVE — default on; set false to block Reloadly adapter while mock may still work.
# WEBTOPUP_VELOCITY_SESSION_WINDOW_MS — rolling window for session create burst signals (default 600000).
# WEBTOPUP_VELOCITY_SESSION_ORDERS_WARN — soft fraud flag threshold (default 8).
# WEBTOPUP_VELOCITY_PHONE_HOUR_ORDERS_WARN — per phone+country per UTC hour (default 12).
# WEBTOPUP_VELOCITY_PHONE_HOUR_SAME_AMOUNT_WARN — same amount repetition in hour (default 6).
# User.role for staff: admin | operator | viewer — operators can dispatch with JSON { "reason": "…" } (min 8 chars).

# === Push notifications (FCM) — inbox + device tokens; does not touch payment/fulfillment code paths ===
# PUSH_NOTIFICATIONS_ENABLED — default on; set false to record inbox rows but skip FCM sends.
# FIREBASE_SERVICE_ACCOUNT_JSON — single-line JSON of Firebase service account (same as GOOGLE_APPLICATION_CREDENTIALS file).
# PUSH_LOYALTY_PER_HOUR_MAX — cap loyalty category notifications per user per rolling hour (default 4).

# Optional overrides (server/.env.local loads after .env and overrides)
