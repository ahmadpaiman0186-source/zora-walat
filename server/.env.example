# Database (SQLite for dev; set postgres URL in production)
DATABASE_URL="file:./dev.db"

# Stripe — paste real values from the Stripe Dashboard (never commit .env)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: reject payment-intent without this header (X-Api-Key: ...)
BFF_API_KEY=""

# Admin read-only dashboard seed (GET /admin/wallet)
ADMIN_API_KEY=""

# Reloadly Airtime (sandbox: topups-sandbox.reloadly.com)
RELOADLY_SANDBOX="true"
RELOADLY_CLIENT_ID=""
RELOADLY_CLIENT_SECRET=""

# Operator IDs from Reloadly dashboard (Afghanistan — fetch via GET /operators?countryCode=AF)
RELOADLY_OPERATOR_ROSHAN=""
RELOADLY_OPERATOR_MTN=""
RELOADLY_OPERATOR_ETISALAT=""
RELOADLY_OPERATOR_AFGHAN_WIRELESS=""

# Fraud / limits
MAX_TOPUP_USD_CENTS_PER_PHONE_PER_DAY=15000
VELOCITY_MAX_ORDERS_PER_PHONE_PER_HOUR=8

# Server
PORT=8787
