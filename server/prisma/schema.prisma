// Production: PostgreSQL only. Apply migrations with `npm run db:migrate` (deploy) or
// `npm run db:migrate:dev` (development). Prisma `$transaction` uses the database
// isolation level (PostgreSQL defaults are fine for concurrent checkout + webhook updates).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Platform commission wallet (10% of captured Stripe amount by default).
model Wallet {
  id           String @id
  balanceCents Int    @default(0)
  updatedAt    DateTime @updatedAt
}

model LedgerEntry {
  id                 String   @id @default(cuid())
  walletId           String
  stripePaymentId    String?
  amountCents        Int
  direction          String // CREDIT | DEBIT (adjustments)
  reason             String
  metadata           String? // JSON string
  createdAt          DateTime @default(now())

  @@index([walletId])
}

model TopupOrder {
  id                    String   @id @default(cuid())
  stripePaymentIntentId String   @unique
  idempotencyKey        String?  @unique
  status                String // PENDING | PAID | FULFILLING | FULFILLED | FULFILLMENT_FAILED
  operatorKey           String
  recipientE164         String
  recipientNational     String
  productId             String
  amountUsdCents        Int
  commissionCents       Int
  reloadlyTransactionId String?
  reloadlyReference     String?
  failureReason         String?
  fraudScore            Int      @default(0)
  clientIp              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([status, createdAt])
}

/// Next.js marketing checkout top-up (session-scoped, Payment Element + webhook lifecycle).
/// Distinct from legacy `TopupOrder` (Reloadly / operator pipeline).
/// Optional `userId`: set when order is created with a valid Bearer token (account binding for support/reconciliation).
model WebTopupOrder {
  id                      String    @id
  sessionKey              String
  userId                  String?
  user                    User?     @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  /// Optional client idempotency key (header). Replays with same key return the same order.
  idempotencyKey          String?   @unique
  /// sha256 hex of canonical create payload — must match on idempotent replay.
  payloadHash             String
  originCountry           String
  destinationCountry      String
  productType             String
  operatorKey             String
  operatorLabel           String
  phoneNumber             String
  productId               String
  productName             String
  selectedAmountLabel     String
  amountCents             Int
  currency                String    @default("usd")
  paymentIntentId         String?   @unique
  paymentStatus           String
  /// First transition to `paid` (Stripe webhook / client mark-paid). Backfilled from `updatedAt` for legacy rows.
  paidAt                  DateTime?
  fulfillmentStatus       String
  /// Provider id (e.g. `mock`, `reloadly`) — set when fulfillment is claimed.
  fulfillmentProvider           String?
  fulfillmentAttemptCount       Int       @default(0)
  fulfillmentRequestedAt        DateTime?
  fulfillmentCompletedAt        DateTime?
  fulfillmentFailedAt           DateTime?
  /// When set, background worker may transition FAILED → PENDING and re-dispatch (retryable errors only).
  fulfillmentNextRetryAt        DateTime?
  /// Provider correlation id (safe subset only in public/admin DTOs).
  fulfillmentReference          String?
  /// Stable machine code (e.g. `retryable`, `terminal`, provider codes).
  fulfillmentErrorCode          String?
  fulfillmentErrorMessageSafe   String?
  /// sha256 hex of last normalized provider request (audit / idempotency aid).
  lastProviderPayloadHash       String?
  updateTokenHash         String
  /// First Stripe `evt_…` that marked this row paid (webhook replay / duplicate protection).
  completedByStripeEventId String? @unique
  /// Non-blocking fraud / velocity flags (JSON). Never store PANs, API secrets, or raw webhook bodies.
  fraudSignals              Json?
  /// sha256 hex — destination + normalized national digits only (analytics / velocity correlation).
  phoneAnalyticsHash        String?
  /// 0–100 risk score from internal engine (non-blocking).
  riskScore                 Int       @default(0)
  /// low | medium | high
  riskLevel                 String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([sessionKey, createdAt])
  @@index([userId, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([paymentStatus, paidAt])
  @@index([fulfillmentStatus, createdAt])
  @@index([fulfillmentStatus, fulfillmentNextRetryAt])
  @@index([phoneAnalyticsHash])
}

/// Client-supplied idempotency for admin dispatch/retry (safe replay, no duplicate provider intent).
model WebTopupFulfillmentIdempotency {
  id                         String   @id @default(cuid())
  orderId                    String
  idempotencyKey             String
  /// pending | completed | failed
  status                     String
  fulfillmentStatusSnapshot  String?
  fulfillmentErrorCodeSnapshot String?
  attemptNumber              Int?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([orderId, idempotencyKey])
  @@index([orderId])
}

/// Durable per-provider circuit breaker for WebTopup outbound provider calls (multi-instance safe).
/// Currently used for Reloadly; `mock` may use in-memory breaker only.
model WebtopupProviderCircuitState {
  providerId String @id
  /// closed | open | half_open
  state                String
  openedAt             DateTime?
  cooldownUntil        DateTime?
  /// Epoch ms JSON array — rolling failure window
  failureTimestamps    Json      @default("[]")
  halfOpenProbesUsed   Int       @default(0)
  lastSuccessAt        DateTime?
  lastFailureAt        DateTime?
  updatedAt            DateTime  @updatedAt
}

/// Queue worker jobs for async web top-up fulfillment (deduped per order attempt).
model WebTopupFulfillmentJob {
  id          String   @id @default(cuid())
  orderId     String
  dedupeKey   String   @unique
  /// Optional admin Idempotency-Key for post-job idempotency completion.
  clientIdempotencyKey String?
  /// queued | processing | completed | dead_letter
  status      String
  attempt     Int      @default(0)
  maxAttempts Int      @default(5)
  nextRunAt   DateTime @default(now())
  lastError   String?
  /// Set when status becomes processing — used for stale lease recovery.
  processingStartedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, nextRunAt])
  @@index([status, processingStartedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  event     String
  payload   String // JSON
  ip        String?
  createdAt DateTime @default(now())
}

model VelocityWindow {
  id           String @id @default(cuid())
  phoneHash    String
  windowHour   String // yyyy-mm-ddTHH (UTC hour bucket)
  totalCents   Int    @default(0)
  orderCount   Int    @default(0)
  @@unique([phoneHash, windowHour])
}

/// Configurable sender region (US, CA, EU, AE, TR) — risk buffer for Phase 1 pricing only.
model SenderCountry {
  code                String   @id
  displayName         String
  enabled             Boolean  @default(true)
  /// Percent of provider cost (e.g. 1.25 = 1.25%).
  riskBufferPercent   Float    @default(0)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Server-authoritative Stripe Checkout attempt (idempotency + webhook lifecycle).
/// `status`: legacy Stripe row state (INITIATED → CHECKOUT_CREATED → …).
/// `orderStatus`: canonical business lifecycle (PENDING → PAID → PROCESSING → FULFILLED | FAILED | CANCELLED).
model PaymentCheckout {
  id                      String   @id @default(cuid())
  idempotencyKey          String   @unique
  requestFingerprint      String
  stripeCheckoutSessionId String?  @unique
  stripeCheckoutUrl       String?
  status                  String
  amountUsdCents          Int
  currency                String   @default("usd")
  /// ISO sender region for analytics & risk buffer (Phase 1: US | CA | EU | AE | TR).
  senderCountryCode       String?
  /// Phase 1 active product: `mobile_topup` only. Future: `data_package`, `calling_credit`.
  productType             String   @default("mobile_topup")
  /// Locked at checkout creation from pricing engine (USD cents).
  providerCostUsdCents          Int?
  stripeFeeEstimateUsdCents     Int?
  stripeFeeActualUsdCents       Int?
  fxBufferUsdCents              Int?
  riskBufferUsdCents            Int?
  targetProfitUsdCents          Int?
  /// Net margin on revenue, basis points (300 = 3.00%).
  projectedNetMarginBp          Int?
  /// Margin using **locked** provider cost + **actual** Stripe fee (when fee captured).
  actualNetMarginBp             Int?
  /// Best-known margin bp: actual provider cost when available, else locked; actual Stripe fee when available, else estimate.
  refinedActualNetMarginBp      Int?
  financialTruthComputedAt      DateTime?
  /// Wholesale/settlement cost in USD cents when provider response exposes it (else null).
  providerCostActualUsdCents    Int?
  /// provider_api | locked_estimate | unverified
  providerCostTruthSource       String?
  fulfillmentProviderReference  String?
  fulfillmentProviderKey        String?
  /// Sanitized fulfillment proof (refs, operator hints, safe provider fields).
  fulfillmentTruthSnapshot      Json?
  /// JSON array of anomaly code strings (e.g. LOW_MARGIN, STRIPE_AMOUNT_MISMATCH).
  financialAnomalyCodes         Json?
  /// Gross amount from Stripe BalanceTransaction (cents); for reconciliation vs amountUsdCents.
  stripeBalanceTransactionAmountCents Int?
  /// Full pricing breakdown JSON for audit (immutable snapshot).
  pricingSnapshot               Json?
  operatorKey             String?
  recipientNational       String?
  packageId               String?
  /// Set for all new sessions; null only on legacy rows before user-scoped checkout.
  userId                  String?
  user                    User?    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /// Canonical order lifecycle for APIs and delivery (see `src/constants/orderStatus.js`; terminal success stored as FULFILLED / DELIVERED alias).
  orderStatus                  String    @default("PENDING")
  provider                     String    @default("stripe")
  clientOrigin                 String?
  failureReason                String?
  metadata                     Json?
  stripePaymentIntentId        String?   @unique
  stripeCustomerId             String?
  /// Stripe event id (`evt_…`) that first transitioned this order to PAID (idempotent completion).
  completedByWebhookEventId    String?   @unique
  paidAt                       DateTime?
  failedAt                     DateTime?
  cancelledAt                  DateTime?
  /// Pricing intelligence (admin-only): captured once at DELIVERED. Amounts USD cents; marginPercentBp = net/sell * 10000.
  marginSellUsdCents           Int?
  marginProviderCostUsdCents   Int?
  /// provider_api | estimated_face_bps
  marginProviderCostSource     String?
  marginPaymentFeeUsdCents     Int?
  marginNetUsdCents            Int?
  marginPercentBp              Int?
  marginCalculatedAt           DateTime?
  /// Phase 1 post-payment incident (manual + optional future webhooks). See `postPaymentIncidentStatus.js`.
  postPaymentIncidentStatus    String?
  postPaymentIncidentNotes     String?   @db.Text
  postPaymentIncidentUpdatedAt DateTime?
  /// How incident was tied to checkout (`REFUND_*`, `DISPUTE_*` constants). See `postPaymentIncidentMapSource.js`.
  postPaymentIncidentMapSource String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@index([userId, orderStatus, createdAt])

  fulfillmentAttempts FulfillmentAttempt[]
}

/// One row per fulfillment try for a payment order; supports retries via `attemptNumber`.
model FulfillmentAttempt {
  id                String   @id @default(cuid())
  orderId           String
  order             PaymentCheckout @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  provider          String   @default("mock")
  /// QUEUED | PROCESSING | SUCCEEDED | FAILED
  status            String
  attemptNumber     Int
  providerReference String?
  /// JSON, non-sensitive request summary for provider integration.
  requestSummary    String?
  /// JSON, non-sensitive response summary.
  responseSummary   String?
  failureReason     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?

  @@unique([orderId, attemptNumber])
  @@index([orderId, status])
  @@index([status, createdAt])
}

/// Processed Stripe webhook event ids (evt_…) — idempotent handling across retries and multiple app instances.
/// `id` is the primary key (globally unique); duplicate inserts fail with P2002 and are acked without side effects.
model StripeWebhookEvent {
  id         String   @id
  receivedAt DateTime @default(now())
}

/// Source aggregate for canonical transaction mirror (additive Phase 4 engine).
enum CanonicalTransactionSourceModel {
  WEBTOPUP
  PHASE1
  WALLET
}

/// Unified lifecycle projection — mirrored from domain tables, not a second SoT for money movement.
enum CanonicalTransactionPhase {
  PENDING
  PAYMENT_INITIATED
  PAYMENT_CONFIRMED
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

/// DB-backed canonical transaction row — **mirror only**; domain tables remain authoritative.
/// Rollback: drop table + enums via migration revert (no impact on payments/orders).
model CanonicalTransaction {
  id                String                        @id @default(uuid())
  sourceModel       CanonicalTransactionSourceModel
  sourceId          String
  userId            String?
  amount            Int
  currency          String                        @default("usd")
  provider          String?
  externalPaymentId String?
  idempotencyKey    String                        @unique
  phase             CanonicalTransactionPhase
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@unique([sourceModel, sourceId])
  @@index([phase, updatedAt])
  @@index([externalPaymentId])
  @@index([userId])
}

/// Per-user balance for mock wallet — PostgreSQL-backed (multi-instance safe).
model UserWallet {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Integer USD cents — avoids float drift; API still exposes decimal dollars for compatibility.
  balanceUsdCents Int
  /// Non-withdrawable credits (e.g. referral rewards) — must be spent on top-ups before general balance when supported at checkout.
  promotionalBalanceUsdCents Int @default(0)
  currency        String   @default("USD")
  updatedAt       DateTime @updatedAt
}

/// Destination number for recharge/data/calling — normalized E.164, scoped to owning user.
model Recipient {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  e164               String
  countryCode        String   @default("AF")
  operatorKey        String?
  label              String?
  verificationStatus String   @default("UNVERIFIED")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, e164])
  @@index([userId])
  @@index([e164])
  @@index([countryCode])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  /// Application values: "user" | "admin" | "operator" | "viewer" (staff roles for /api/admin/*).
  role          String   @default("user")
  /// Set when email ownership is proven (e.g. OTP verify). Null = never verified.
  emailVerifiedAt DateTime?
  /// Increment to invalidate all outstanding access JWTs (password change / global revoke).
  tokenVersion  Int      @default(0)
  isActive      Boolean  @default(true)
  /// Lifetime loyalty points (completed paid + delivered checkouts only); see LoyaltyPointsGrant.
  loyaltyPointsTotal Int  @default(0)
  /// Shareable code; assigned lazily or at registration (see referral service).
  referralCode  String?  @unique
  /// HMAC digest for abuse checks (never store raw IP).
  signupIpHash  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens      RefreshToken[]
  paymentCheckouts   PaymentCheckout[]
  userWallet         UserWallet?
  recipients         Recipient[]
  loyaltyGrants      LoyaltyPointsGrant[]
  familyMembership   FamilyGroupMember?
  ownedFamilyGroups  FamilyGroup[]       @relation("FamilyGroupOwner")
  pushDevices        PushDevice[]
  notifications      UserNotification[]
  referralsAsInviter Referral[]             @relation("ReferralInviter")
  referralAsInvitee  Referral?              @relation("ReferralInvitee")
  referralRewards    ReferralRewardTransaction[]
  referralLoyaltyFromInvites ReferralLoyaltyBonus[]
  loyaltyLedgerEntries     LoyaltyLedger[]
  walletTopupIdempotencies  WalletTopupIdempotency[]
  userWalletLedgerEntries   UserWalletLedgerEntry[]
  webTopupOrders            WebTopupOrder[]

  @@index([email])
}

/// Append-only movements for `UserWallet` (audit + future reconciliation). Balance reads stay on `UserWallet` in this phase.
/// DB trigger blocks UPDATE/DELETE; use `referenceId` for external/operator correlation.
model UserWalletLedgerEntry {
  id                   String   @id @default(cuid())
  /// Stable business id (UUID); immutable after insert.
  referenceId          String   @unique
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  direction            String // CREDIT | DEBIT
  reason               String // wallet_topup | wallet_topup_legacy | …
  amountUsdCents       Int
  currency             String   @default("USD")
  balanceAfterUsdCents Int
  /// Set for idempotent `POST /api/wallet/topup`; replays do not insert another row. Null for legacy no-key path (multiple rows allowed).
  idempotencyKey       String?
  /// Arbitrary JSON string (audit / product context).
  metadataJson         String?
  createdAt            DateTime @default(now())

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
}

/// Replay-safe record for POST /api/wallet/topup when client sends Idempotency-Key (UUID).
model WalletTopupIdempotency {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  idempotencyKey  String
  amountUsdCents  Int
  createdAt       DateTime @default(now())

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
}

/// Append-only loyalty credits for audit / replay-safe totals (`sourceId` dedupes side effects).
model LoyaltyLedger {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  source    String
  sourceId  String   @unique
  amount    Int
  type      String   @default("CREDIT")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// Reconciliation incremental / full-scan checkpoints (internal ops).
model ReconciliationWatermark {
  key      String    @id
  cursorAt DateTime?
  cursorId String?
  updatedAt DateTime @updatedAt
}

/// Singleton-style referral program knobs (editable by admin).
model ReferralProgramConfig {
  id                         String   @id @default("default")
  referralEnabled            Boolean  @default(true)
  /// Weekly cap on successful referral payouts (USD cents).
  weeklyBudgetUsdCents       Int      @default(5000)
  /// Inviter reward per qualifying referral (USD cents).
  rewardAmountUsdCents       Int      @default(500)
  /// Minimum first delivered order size for the invitee (USD cents).
  minFirstOrderUsdCents      Int      @default(100)
  /// Max successfully rewarded referrals per inviter (lifetime rolling).
  maxRewardsPerUser          Int      @default(20)
  /// Cap successful payouts per inviter per UTC week (anti-gaming).
  maxRewardsPerInviterPerWeek Int     @default(10)
  /// Delay after fulfillment success before attempting payout (chargeback / fraud buffer).
  rewardDelayMinutes         Int      @default(5)
  /// Extra loyalty points for inviter on each rewarded referral (0 disables).
  referralBonusLoyaltyPoints Int      @default(0)
  /// When true, automated retries skip paused referrals (admin must unset to resume).
  pausePausedQueueProcessing Boolean  @default(false)
  updatedAt                  DateTime @updatedAt
}

/**
 * Inviter → invitee link. `invitedUserId` is unique (one referral attribution per user).
 * Status: PENDING | COMPLETED | REWARDED | REWARD_PAUSED
 */
model Referral {
  id          String    @id @default(cuid())
  inviterUserId String
  invitedUserId String  @unique
  inviter       User    @relation("ReferralInviter", fields: [inviterUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  invited       User    @relation("ReferralInvitee", fields: [invitedUserId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  status        String
  /// Normalized code string applied at signup (audit).
  referralCodeUsed String?
  firstOrderId  String? @unique
  fraudFlags    Json?
  invitedSignupIpHash String?
  appliedIpHash       String?
  appliedDeviceFingerprintHash String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  rewardedAt    DateTime?
  updatedAt     DateTime @updatedAt

  rewardTx ReferralRewardTransaction?
  loyaltyBonus ReferralLoyaltyBonus?

  @@index([inviterUserId, status])
  @@index([status, createdAt])
  @@index([updatedAt])
}

/// Idempotent reward line per referral (`referralId` unique).
model ReferralRewardTransaction {
  id             String   @id @default(cuid())
  userId         String
  referralId     String   @unique
  amountUsdCents Int
  source         String   @default("referral")
  /// COMPLETED | FAILED | PENDING
  status         String
  failureReason  String?
  createdAt      DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  referral Referral @relation(fields: [referralId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

/// Loyalty bonus for inviter on rewarded referral (separate from checkout-based grants).
model ReferralLoyaltyBonus {
  id         String   @id @default(cuid())
  referralId String   @unique
  userId     String
  points     Int
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  referral Referral @relation(fields: [referralId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([userId])
}

/// FCM registration token (Android/iOS/Web) — one row per device token; cascade on user delete.
model PushDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fcmToken  String   @unique
  platform  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// Server-authoritative notification inbox + idempotent push dedupe (`userId` + `dedupeKey`).
model UserNotification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dedupeKey   String
  category    String
  title       String
  body        String
  payloadJson String?
  createdAt   DateTime  @default(now())
  readAt      DateTime?

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt])
}

/// One family / household group for shared points visibility (not gambling; skill-free loyalty).
model FamilyGroup {
  id          String   @id @default(cuid())
  name        String
  ownerUserId String
  owner       User     @relation("FamilyGroupOwner", fields: [ownerUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /// Short code for invites (unique, rate-limited on join).
  inviteCode  String   @unique
  /// Denormalized sum of all completed checkout points earned while members were in group (see grants).
  totalPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members FamilyGroupMember[]
  grants  LoyaltyPointsGrant[] @relation("GrantGroup")

  @@unique([ownerUserId])
  @@index([totalPoints])
}

/// At most one group per user (simple family model).
model FamilyGroupMember {
  id       String      @id @default(cuid())
  groupId  String
  group    FamilyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId   String      @unique
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role     String      @default("member") // owner | member
  joinedAt DateTime    @default(now())

  @@unique([groupId, userId])
  @@index([groupId])
}

/// Idempotent: one row per delivered PaymentCheckout — prevents double-counting.
model LoyaltyPointsGrant {
  id                 String   @id @default(cuid())
  paymentCheckoutId  String   @unique
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  /// Group at earn time (nullable if user was not in a group).
  groupId            String?
  group              FamilyGroup? @relation("GrantGroup", fields: [groupId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  points             Int
  amountUsdCents     Int
  /// UTC month key `yyyy-MM` for monthly leaderboard aggregation.
  leaderboardMonth   String
  createdAt          DateTime @default(now())

  @@index([userId, leaderboardMonth])
  @@index([groupId, leaderboardMonth])
  @@index([leaderboardMonth])
}

/// Frozen monthly ranks for audit / “closed month” reads (no randomness; deterministic from spend).
model LoyaltyLeaderboardSnapshot {
  id         String   @id @default(cuid())
  yearMonth  String
  scope      String // GROUP | USER
  subjectId  String
  points     Int
  rank       Int
  capturedAt DateTime @default(now())

  @@unique([yearMonth, scope, subjectId])
  @@index([yearMonth, scope, rank])
}

/// Reward tier definitions only (distribution not implemented). Rank bands are global monthly placement.
model LoyaltyRewardTier {
  id          String   @id @default(cuid())
  rankStart   Int
  rankEnd     Int?
  label       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sortOrder])
}

/// Server-side refresh tokens (hash only). Rotation invalidates previous token in the same chain.
model RefreshToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId   String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

/// Email OTP challenge for passwordless sign-in. Stores only hashed OTP material.
model AuthOtpChallenge {
  id              String   @id @default(cuid())
  email           String
  otpHash         String
  expiresAt       DateTime
  resendAfter     DateTime
  attemptsCount   Int      @default(0)
  requestCount    Int      @default(1)
  lockedUntil     DateTime?
  consumedAt      DateTime?
  lastSentAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([email])
  @@index([expiresAt])
  @@index([lockedUntil])
}
