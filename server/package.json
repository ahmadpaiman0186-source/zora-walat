    "proof:webtopup:phase13:env": "node scripts/webtopup-phase13-proof.mjs --load-env",
    "reconciliation:scan": "node scripts/reconciliation-scan.mjs",
    "test": "node scripts/run-unit-tests.mjs",
    "test:integration:preflight": "node scripts/integration-preflight.mjs",
    "test:integration": "node --test-force-exit --test-concurrency=1 --import ./test/integrations/preloadTestDatabaseUrl.mjs --test test/integrations/authOtp.integration.test.js test/integrations/apiContractAuthFlow.integration.test.js test/integrations/verifiedMoneyPath.integration.test.js test/integrations/phase1MoneyPath.test.js test/integrations/phase1Resilience.integration.test.js test/integrations/moneyPathReconInconsistent.integration.test.js test/integrations/transactionFortressConcurrency.integration.test.js test/integrations/walletTopupIdempotency.integration.test.js test/integrations/webTopupPaymentIntentSession.integration.test.js test/integrations/webTopupOrderUserBinding.integration.test.js test/integrations/readinessWatchdog.integration.test.js test/integrations/sprint4PaymentLoopProof.integration.test.js test/integrations/sprint5ReconciliationTraceability.integration.test.js && node --test-force-exit --test-concurrency=1 --import ./test/integrations/preloadTestDatabaseUrl.mjs --import ./test/integrations/registerChaosWebhookEnv.mjs --test test/integrations/stripeWebhookHttpChaos.integration.test.js",
    "test:integration:sprint4": "node --test-force-exit --test-concurrency=1 --import ./test/integrations/preloadTestDatabaseUrl.mjs --test test/integrations/sprint4PaymentLoopProof.integration.test.js",
    "test:integration:sprint5": "node --test-force-exit --test-concurrency=1 --import ./test/integrations/preloadTestDatabaseUrl.mjs --test test/integrations/sprint5ReconciliationTraceability.integration.test.js",
    "proof:sprint5": "node scripts/sprint5-reconciliation-proof.mjs",
    "proof:sprint5:stripe-api": "node scripts/stripe-test-mode-api-proof.mjs",
    "proof:sprint5:db": "node scripts/stripe-phase1-reconciliation-db-proof.mjs",
    "proof:stripe:webhook-transport": "node scripts/stripe-local-webhook-transport-proof.mjs",
    "proof:canonical-order-lifecycle": "node scripts/proof-canonical-order-lifecycle.mjs",
    "verify:wallet-topup-idempotency": "node --import ./test/integrations/preloadTestDatabaseUrl.mjs --test test/integrations/walletTopupIdempotency.integration.test.js",
    "verify:wallet-topup-http": "node scripts/wallet-topup-local-verify.mjs",
    "verify:wallet": "node scripts/wallet-topup-local-verify.mjs",
    "verify:wallet:replay": "node scripts/wallet-topup-local-verify.mjs --replay",
    "verify:local-pricing": "node scripts/verify-local-pricing-runtime.mjs",
    "load:wallet:replay": "node scripts/wallet-topup-load.mjs --mode=replay",
    "load:wallet:apply": "node scripts/wallet-topup-load.mjs --mode=apply",
    "smoke:wallet:unauthed": "node scripts/wallet-topup-load.mjs --smoke-unauthed",
    "smoke:wallet:no-idem": "node scripts/wallet-topup-load.mjs --smoke-no-idem",
    "test:ci": "npm run test && node scripts/maybe-migrate-integration-database.mjs && npm run test:integration",
    "ci:integration-verify": "node scripts/ci-integration-verify.mjs",
    "verify:ci-local": "node scripts/ci-verify-local.mjs",
    "reloadly:golden-path-preflight": "node scripts/reloadly-golden-path-preflight.mjs",
    "phase1:launch-readiness": "node scripts/phase1-launch-readiness.mjs",
    "phase1:launch-readiness:strict": "node scripts/phase1-launch-readiness.mjs --strict",
    "phase1:scale-sanity": "node scripts/phase1-scale-sanity.mjs",
    "phase1:money-path-load": "node scripts/phase1-money-path-load.mjs",
    "fortress:concurrency-probe": "node scripts/transaction-fortress-concurrency-probe.mjs",
    "gate:check": "node scripts/gate-check.mjs",
    "gate:check:strict": "node scripts/gate-check.mjs --strict",
    "gate:check:scale": "node scripts/gate-check.mjs --strict --scale"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.0.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "p-limit": "^6.2.0",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "prisma": "^6.15.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "serverless-http": "^3.2.0",
    "stripe": "^18.5.0",
    "zod": "^4.1.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
