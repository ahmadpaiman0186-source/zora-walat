    "postinstall": "node scripts/postinstall-prisma.mjs",
    "generate": "prisma generate",
    "start": "node start.js",
    "worker:fulfillment": "node fulfillment-worker.mjs",
    "dev": "node --watch start.js",
    "db:push": "node scripts/prisma-cli.mjs db push",
    "db:migrate": "node scripts/prisma-cli.mjs migrate deploy",
    "db:migrate:integration": "node scripts/migrate-integration-database.mjs",
    "db:migrate:dev": "node scripts/prisma-cli.mjs migrate dev",
    "db:validate": "node scripts/prisma-cli.mjs validate",
    "db:studio": "node scripts/prisma-cli.mjs studio",
    "db:health": "node scripts/test-db-connection.mjs",
    "auth:check-user": "node scripts/check-user-eligibility.mjs",
    "auth:probe-otp": "node scripts/incident-otp-identity-probe.mjs",
