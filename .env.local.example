# Stripe publishable key only (never put sk_ or whsec_ in the frontend project).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Public API origin: must match the **production** backend hostname and must NOT use a
# Vercel preview URL that has Deployment Protection (SSO) enabled.
NEXT_PUBLIC_API_URL=https://your-api-host.example

# Local dev (copy to `.env.local`): Next.js marketing top-up calls this origin for
# `POST /api/topup-orders` and `POST /create-payment-intent`. If unset, checkout stays on
# "Securing checkout…" only briefly before failing — it must not be empty for local E2E.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8787

# Optional: absolute URL for Stripe.js `confirmPayment({ confirmParams: { return_url } })`.
# Defaults to the current browser URL (fine for localhost). Set in production if you need a fixed landing page after redirect-based payment methods.
# NEXT_PUBLIC_STRIPE_RETURN_URL=http://127.0.0.1:3000/
